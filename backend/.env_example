# ========================================
# DATABASE
# ========================================
DB_USER=user
DB_PASSWORD=user
DB_HOST=localhost
DB_PORT=5432
DB_NAME=qrisdatabase

# ========================================
# REDIS CACHE
# ========================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ========================================
# RABBITMQ MESSAGE BROKER
# ========================================
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ========================================
# CORS - Cross-Origin Resource Sharing
# ========================================
CORS_ALLOWED_ORIGINS=http://192.168.1.18:5173,http://127.0.0.1:5173,http://192.168.1.18:5174,http://127.0.0.1:5174

# ========================================
# WEBSOCKET - Optimized for Low Latency
# ========================================
# Read deadline: 5 minutes (300 seconds)
# Why 5 min? Browser/network is generally stable for this duration
# Reduces unnecessary ping traffic by 95%+ vs short timeouts
WEBSOCKET_READ_DEADLINE=5m

# Write deadline: 10 seconds
# Standard timeout for write operations
WEBSOCKET_WRITE_DEADLINE=10s

# Idle check interval: 60 seconds
# Only CHECK if need to send ping, don't actually send unless idle > 4 min
WEBSOCKET_IDLE_CHECK_INTERVAL=1m

# Idle threshold: 240 seconds (4 minutes)
# Only send ping if no message received for 4 minutes
WEBSOCKET_IDLE_THRESHOLD=4m

# Max message size: 64KB
# For merchant notifications, 64KB is plenty
WEBSOCKET_MAX_MESSAGE_SIZE=65536

# ========================================
# PGADMIN
# ========================================
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin

# ========================================
# INFLUXDB
# ========================================
INFLUXDB_DB=k6

# ========================================
# GRAFANA
# ========================================
GF_AUTH_ANONYMOUS_ENABLED=true
GF_AUTH_ANONYMOUS_ORG_ROLE=Admin

# ========================================
# APPLICATION
# ========================================
ENVIRONMENT=development
SERVER_PORT=8080
LOG_LEVEL=info